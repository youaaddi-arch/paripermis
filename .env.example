# Sanity (CMS des formations) — valeurs par défaut intégrées au code,
# à surcharger ici ou dans les variables d'environnement Vercel si besoin.
VITE_SANITY_PROJECT_ID=yguvu8t3
VITE_SANITY_DATASET=production

# Token d'écriture Sanity — UNIQUEMENT pour exécuter le script de seed en local.
# Ne jamais committer une vraie valeur. Générer sur https://www.sanity.io/manage
# SANITY_WRITE_TOKEN=

# Chatbot IA — clé API Anthropic du gestionnaire du site.
# À définir dans les variables d'environnement Vercel (et non dans le code).
# Sans cette clé, le chatbot affiche un message invitant à contacter le centre.
# Obtenir une clé : https://console.anthropic.com/
# ANTHROPIC_API_KEY=
